[Unit]
Description=Hardpoint Agent
Documentation=https://docs.hardpoint.dev
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hardpoint
Group=hardpoint
ExecStart=/usr/bin/hardpointd listen
Restart=on-failure
RestartSec=5s

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/hardpointd

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hardpointd

[Install]
WantedBy=multi-user.target